@model PaymentSuccessViewModel

@{
    ViewData["Title"] = "Payment Successful";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 text-center">

                <%-- Success Icon --%>
                    <div class="mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10"
                             style="width: 88px; height: 88px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40"
                                 fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="2.2" style="color: #198754;">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M5 13l4 4L19 7" />
                            </svg>
                        </div>
                    </div>

                    <%-- Heading --%>
                        <h1 class="h3 fw-semibold mb-1">Payment Successful!</h1>
                        <p class="text-secondary mb-4">
                            Thank you for your purchase. Your order has been confirmed.
                        </p>

                        <%-- Order Details Card --%>
                            <div class="bg-light rounded-3 px-4 py-3 mb-4 text-start">
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-secondary small">Order ID</span>
                                    <span class="fw-semibold text-dark">#@Model.OrderId</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-secondary small">Date</span>
                                    <span class="fw-semibold text-dark">@Model.OrderDate.ToString("MMMM dd, yyyy")</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-secondary small">Payment Method</span>
                                    <span class="fw-semibold text-dark">@Model.PaymentMethod</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center pt-3">
                                    <span class="fw-semibold">Total Paid</span>
                                    <span class="fs-5 fw-bold text-success">@Model.TotalPrice.ToString("C")</span>
                                </div>
                            </div>

                            <%-- Email note --%>
                                <p class="text-secondary small mb-4">
                                    A confirmation email has been sent to
                                    <strong>@Model.Email</strong>.
                                    Please keep your order ID for reference.
                                </p>

                                <%-- Actions --%>
                                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                                        <a asp-action="Details" asp-controller="Orders" asp-route-id="@Model.OrderId"
                                               class="btn btn-success px-4">
                                            View Order
                                        </a>
                                        <a asp-action="Index" asp-controller="Home"
                                               class="btn btn-outline-secondary px-4">
                                            Back to Home
                                        </a>
                                    </div>

                                </div>

                                <%-- Support link --%>
                                    <p class="text-center text-secondary small mt-4">
                                        Need help?
                                        <a asp-action="Contact" asp-controller="Support" class="text-decoration-none">Contact Support</a>
                                    </p>

                                </div>
                            </div>
                        </div>
