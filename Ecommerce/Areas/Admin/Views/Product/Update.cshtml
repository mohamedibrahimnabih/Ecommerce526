@model ProductWithSubImgsVM

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Update Product</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="Name" class="form-label">Name</label>
                    <input class="form-control" placeholder="Name" name="name" value="@Model.Product.Name">
                </div>
                <div class="mb-3">
                    <div class="mb-3">
                        <label for="Description" class="form-label">Description</label>
                        <textarea class="form-control" id="Description" rows="3">@Model.Product.Description</textarea>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="Price" class="form-label">Price</label>
                    <input class="form-control" placeholder="Price" name="Price" value="@Model.Product.Price">
                </div>
                <div class="mb-3">
                    <label for="Discount" class="form-label">Discount</label>
                    <input class="form-control" placeholder="Discount" name="Discount" value="@Model.Product.Discount">
                </div>

                <div class="mb-3">
                    <label for="CategoryName" class="form-label">Category Name</label>
                    <select name="CategoryId" class="form-select">
                        @foreach (var item in Model.Categories)
                        {
                            @if (@ViewBag.CategoryId == item.Id)
                            {
                                <option value="@item.Id" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="BrandName" class="form-label">Brand Name</label>
                    <select name="BrandId" class="form-select">
                        @foreach (var item in Model.Brands)
                        {
                            @if (@ViewBag.BrandId == item.Id)
                            {
                                <option value="@item.Id" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label for="Img" class="form-label">Img</label>
                    <input type="file" class="form-control" id="Img" name="Img" onchange="previewImage(event)">
                </div>

                <div class="mb-3">
                    <img id="preview"
                         src="~/images/products/@Model.Product.MainImg"
                         alt="Current Image"
                         style="max-width: 200px; border:1px solid #ccc; padding:5px; border-radius:10px;" />
                </div>

                <div class="mb-3">
                    <label for="SubImgs" class="form-label">Sub Imgs</label>
                    <input type="file" class="form-control" id="SubImgs" name="SubImgs" multiple>
                </div>

                <div class="mb-3">
                    @foreach (var item in Model.ProductSubImgs)
                    {
                        <img id="preview"
                             src="~/images/products/SubImgs/@item.SubImg"
                             alt="Current Image"
                             style="max-width: 200px; border:1px solid #ccc; padding:5px; border-radius:10px;" />
                    }
                </div>

                <div class="mb-3">
                    <label for="Status" class="form-label">Status</label>
                    <select name="status" class="form-select" id="Status">
                        @if (Model.Product.Status)
                        {
                            <option value="true" selected>Active</option>
                            <option value="false">In Active</option>
                        }
                        else
                        {
                            <option value="true">Active</option>
                            <option value="false" selected>In Active</option>
                        }
                    </select>

                    @* <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="status" value="(@Model.Status) ? 'true' : 'false'" id="checkDefault">
                        <label class="form-check-label" for="checkDefault">
                            Active / In Active
                        </label>
                    </div> *@
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>

<script>
    function previewImage(event) {
        const input = event.target;
        const preview = document.getElementById("preview");

        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result; // الصورة الجديدة
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
